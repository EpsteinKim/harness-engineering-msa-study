{
  "uid": "harness-ops",
  "title": "Harness Operations",
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "" },
        "query": "label_values(jvm_memory_used_bytes, app)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{app=~\"$service\"}[1m])) by (app)",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "title": "HTTP Latency P95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{app=~\"$service\"}[1m])) by (le, app)) * 1000",
          "legendFormat": "{{app}} p95"
        }
      ]
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 15 } }
      },
      "targets": [
        {
          "expr": "sum(kafka_consumer_records_lag_max{app=~\"$service\"}) by (app, topic)",
          "legendFormat": "{{app}} / {{topic}}"
        }
      ]
    },
    {
      "title": "Kafka Consumer Rate (records/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum(rate(kafka_consumer_fetch_manager_records_consumed_total{app=~\"$service\"}[1m])) by (app)",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "title": "HikariCP Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{app=~\"$service\"}",
          "legendFormat": "{{app}} active"
        },
        {
          "expr": "hikaricp_connections_idle{app=~\"$service\"}",
          "legendFormat": "{{app}} idle"
        },
        {
          "expr": "hikaricp_connections_pending{app=~\"$service\"}",
          "legendFormat": "{{app}} pending"
        }
      ]
    },
    {
      "title": "JVM Heap Used (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\", app=~\"$service\"}) by (app) / 1024 / 1024",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "title": "Redis Memory Usage (MB)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "decmbytes" } },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "legendFormat": "Used"
        }
      ]
    },
    {
      "title": "Redis Connected Clients",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Clients"
        }
      ]
    },
    {
      "title": "JVM Threads",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{app=~\"$service\"}",
          "legendFormat": "{{app}}"
        }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "process_uptime_seconds{app=~\"$service\"}",
          "legendFormat": "{{app}}"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
