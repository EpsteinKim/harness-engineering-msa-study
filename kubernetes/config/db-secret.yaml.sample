  RESERVE_DB_PASSWORD: "harness"
  PAYMENT_DB_URL: "jdbc:postgresql://host.docker.internal:5432/payment_db"
  PAYMENT_DB_USERNAME: "harness"
  PAYMENT_DB_PASSWORD: "harness"
